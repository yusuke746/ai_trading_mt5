# === OpenAI API ===
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-5-mini
OPENAI_FINAL_APPROVAL_ENABLED=true
OPENAI_FINAL_APPROVAL_MODEL=gpt-5.2
OPENAI_FINAL_APPROVAL_REASONING_EFFORT=medium
FINAL_APPROVAL_SYMBOLS=GOLD,US100Cash
FINAL_APPROVAL_MIN_CONFIDENCE=75

# === Discord Webhook ===
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXXXX/YYYYYYYYYY

# === MT5 (XMTrading) ===
MT5_PATH=C:\Program Files\XMTrading MT5\terminal64.exe
MT5_LOGIN=12345678
MT5_PASSWORD=your_password_here
MT5_SERVER=XMTrading-MT5

# === Trading Parameters ===
# リスク: 1トレードあたり残高の何% (0.02 = 2%)
RISK_PER_TRADE=0.02
# 最大ロット数
MAX_LOT=1.0
# 同一通貨グループ最大ポジション数
MAX_CORRELATED_POSITIONS=2

# 保有中AI監視足
EXIT_MONITOR_TF=M15
# EXIT判定の最小信頼度
EXIT_MIN_CONFIDENCE=45
# エントリー根拠崩壊時は信頼度に関係なく強制EXIT
FORCE_EXIT_ON_PREMISE_BREAK=true
# ティックがこの秒数より古ければ市場停止中とみなし、AI判定を止める
MARKET_DATA_STALE_SEC=1800

# 機械式緊急エグジット
EMERGENCY_EXIT_ENABLED=true
EMERGENCY_EXIT_ADVERSE_ATR=1.8
EMERGENCY_EXIT_ATR_SPIKE_MULTIPLIER=1.8
EMERGENCY_EXIT_ATR_SPIKE_LOOKBACK=20

# 利益保護
PROFIT_PROTECTION_ENABLED=true
BREAKEVEN_R=1.0
BREAKEVEN_BUFFER_R=0.10
LOCK_PROFIT_1_TRIGGER_R=1.5
LOCK_PROFIT_1_R=0.50
LOCK_PROFIT_2_TRIGGER_R=2.0
LOCK_PROFIT_2_R=1.00

# エントリー時TP設定（SLに対する倍率）
ENTRY_TP_R=1.2
# AIが小さすぎるTPを返した場合の最小倍率
ENTRY_MIN_TP_R=1.0

# === SQLite Maintenance ===
# 軽量メンテ実行間隔 (秒)
DB_MAINTENANCE_INTERVAL_SEC=3600
# フルVACUUM実行間隔 (秒)
DB_FULL_VACUUM_INTERVAL_SEC=86400
# 保持日数
DB_RETENTION_DAYS_AI_LOGS=14
DB_RETENTION_DAYS_HEARTBEATS=30
DB_RETENTION_DAYS_CLOSED_TRADES=365
